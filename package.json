{
  "name": "exam-cram-agent",
  "version": "0.1.0",
  "description": "期末突击复习 Agent - 大学生期末备考助手",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:front\"",
    "dev:server": "tsx watch --env-file=.env.local src/index.ts --server",
    "dev:front": "cd frontend && npm run dev",
    "dev:cli": "tsx --env-file=.env.local src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/koa": "^3.0.3",
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@koa/bodyparser": "^6.1.0",
    "@koa/router": "^15.6.0",
    "concurrently": "^10.0.3",
    "koa": "^3.2.1",
    "openai": "^6.42.0"
  }
}
